local function Unload()
    RenderSteppedConnection:Disconnect()
    FOVCircle:Remove(); SilentFOVCircle:Remove(); TriggerAimCircle:Remove(); TriggerShootCircle:Remove()
    for _, obj in pairs(ESP_Objects) do
        obj.Box:Remove(); obj.Name:Remove()
        for _, l in pairs(obj.Skeleton) do l:Remove() end
    end
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.HipHeight = Config.Misc.OriginalHipHeight
    end
    Rayfield:Destroy()
end
SettingsTab:CreateButton({ Name = "Finalizar Script", Callback = Unload })

