-- Drawing API Elements
local function CreateCircle(color, filled)
    local c = Drawing.new("Circle")
    c.Visible = false
    c.Thickness = 1
    c.NumSides = 64
    c.Filled = filled or false
    c.Color = color
    return c
end

local FOVCircle = CreateCircle(Color3.fromRGB(255, 255, 255))
local SilentFOVCircle = CreateCircle(Color3.fromRGB(255, 0, 0))
