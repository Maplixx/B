-- Utility Functions
local function CacheCharacter(player)
    if not player.Character then return end
    local char = player.Character
    local parts = {}
    
    local function addPart(name)
        local p = char:FindFirstChild(name)
        if p then parts[name] = p end
    end
    
    addPart("Head")
    addPart("HumanoidRootPart")
    addPart("Humanoid")
    
    local r15 = {"UpperTorso", "LowerTorso", "LeftUpperArm", "LeftLowerArm", "LeftHand", "RightUpperArm", "RightLowerArm", "RightHand", "LeftUpperLeg", "LeftLowerLeg", "LeftFoot", "RightUpperLeg", "RightLowerLeg", "RightFoot"}
    local r6 = {"Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg"}
    
    for _, n in pairs(r15) do addPart(n) end
    for _, n in pairs(r6) do addPart(n) end
    
    CharacterCache[player] = parts
end

local function IsVisible(part)
    if not part then return false end
    local char = LocalPlayer.Character
    if not char then return false end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {char, Camera}
    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin).Unit * (part.Position - origin).Magnitude
    local result = workspace:Raycast(origin, direction, params)
    return result and result.Instance:IsDescendantOf(part.Parent) or false
end

local function GetClosestPlayer(fov, teamCheckEnabled, visibleCheckEnabled, targetPartName)
    local target = nil
    local shortestDistance = fov or math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for player, parts in pairs(CharacterCache) do
        if player ~= LocalPlayer and player.Character and parts.Humanoid and parts.Humanoid.Health > 0 then
            if teamCheckEnabled and player.Team == LocalPlayer.Team then continue end
            
            local part = parts[targetPartName]
            if not part and targetPartName == "HumanoidRootPart" then
                part = parts["Torso"] or parts["UpperTorso"]
            end

            if part then
                if visibleCheckEnabled and not IsVisible(part) then continue end
                local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local distance = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
                    if distance < shortestDistance then
                        target = player
                        shortestDistance = distance
                    end
                end
            end
        end
    end
    return target
end

-- METATABLE HOOKING (Final Polish)
local mt = getrawmetatable(game)
local oldIndex = mt.__index
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__index = newcclosure(function(self, index)
    if not checkcaller() and self == Mouse and (index == "Hit" or index == "Target") then
        if Config.SilentAim.Enabled then
            local target = GetClosestPlayer(Config.SilentAim.FOV, Config.SilentAim.TeamCheck, Config.SilentAim.VisibleCheck, Config.SilentAim.TargetPart)
            if target and CharacterCache[target] then
                local parts = CharacterCache[target]
                local part = parts[Config.SilentAim.TargetPart]
                if not part and Config.SilentAim.TargetPart == "HumanoidRootPart" then
                    part = parts["Torso"] or parts["UpperTorso"]
                end
                
                if part then
                    if index == "Hit" then return part.CFrame end
                    if index == "Target" then return part end
                end
            end
        end
    end
    return oldIndex(self, index)
end)

mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if not checkcaller() and Config.SilentAim.Enabled and method == "Raycast" then
        local target = GetClosestPlayer(Config.SilentAim.FOV, Config.SilentAim.TeamCheck, Config.SilentAim.VisibleCheck, Config.SilentAim.TargetPart)
        if target and CharacterCache[target] then
            local parts = CharacterCache[target]
            local part = parts[Config.SilentAim.TargetPart]
            if not part and Config.SilentAim.TargetPart == "HumanoidRootPart" then
                part = parts["Torso"] or parts["UpperTorso"]
            end
            if part then
                -- Opcional: Redirecionar argumentos do Raycast para jogos que não usam Mouse.Hit
            end
        end
    end
    return oldNamecall(self, ...)
end)

setreadonly(mt, true)

-- Improved Rectangular Touch Detection
local ActiveTouches = {}

UserInputService.InputBegan:Connect(function(input, processed)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        local pos = Vector2.new(input.Position.X, input.Position.Y)
        ActiveTouches[input] = pos
        
        if IsInBox(pos, Config.TriggerAim.Position, Config.TriggerAim.SizeX, Config.TriggerAim.SizeY) then
            Config.Aimbot.AimActive = true
        end
        if IsInBox(pos, Config.TriggerShoot.Position, Config.TriggerShoot.SizeX, Config.TriggerShoot.SizeY) then
            Config.Aimbot.ShootActive = true
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if ActiveTouches[input] then
        local pos = Vector2.new(input.Position.X, input.Position.Y)
        ActiveTouches[input] = pos
        
        -- Update active state if finger moves
        Config.Aimbot.AimActive = false
        Config.Aimbot.ShootActive = false
        for _, tPos in pairs(ActiveTouches) do
            if IsInBox(tPos, Config.TriggerAim.Position, Config.TriggerAim.SizeX, Config.TriggerAim.SizeY) then
                Config.Aimbot.AimActive = true
            end
            if IsInBox(tPos, Config.TriggerShoot.Position, Config.TriggerShoot.SizeX, Config.TriggerShoot.SizeY) then
                Config.Aimbot.ShootActive = true
            end
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if ActiveTouches[input] then
        ActiveTouches[input] = nil
        
        -- Recalculate states based on remaining touches
        Config.Aimbot.AimActive = false
        Config.Aimbot.ShootActive = false
        for _, tPos in pairs(ActiveTouches) do
            if IsInBox(tPos, Config.TriggerAim.Position, Config.TriggerAim.SizeX, Config.TriggerAim.SizeY) then
                Config.Aimbot.AimActive = true
            end
            if IsInBox(tPos, Config.TriggerShoot.Position, Config.TriggerShoot.SizeX, Config.TriggerShoot.SizeY) then
                Config.Aimbot.ShootActive = true
            end
        end
    end
end)

function IsInBox(pos, boxPos, sizeX, sizeY)
    return pos.X >= boxPos.X and pos.X <= boxPos.X + sizeX and
           pos.Y >= boxPos.Y and pos.Y <= boxPos.Y + sizeY
end

-- ESP Logic (Optimized)
local function CreateESP(player)
    local drawings = { Box = Drawing.new("Square"), Name = Drawing.new("Text"), Skeleton = {} }
    drawings.Box.Visible = false; drawings.Box.Color = Config.Visuals.Color; drawings.Box.Thickness = 1; drawings.Box.Filled = false
    drawings.Name.Visible = false; drawings.Name.Color = Config.Visuals.Color; drawings.Name.Size = 14; drawings.Name.Center = true; drawings.Name.Outline = true
    for i = 1, 15 do
        local line = Drawing.new("Line")
        line.Visible = false; line.Color = Config.Visuals.Color; line.Thickness = 1
        drawings.Skeleton[i] = line
    end
    ESP_Objects[player] = drawings
end

local function UpdateESP(player, drawings)
    local parts = CharacterCache[player]
    if not parts or not parts.HumanoidRootPart or not parts.Humanoid or parts.Humanoid.Health <= 0 then
        drawings.Box.Visible = false; drawings.Name.Visible = false
        for _, line in pairs(drawings.Skeleton) do line.Visible = false end
        return
    end
    
    local hrp = parts.HumanoidRootPart
    local head = parts.Head
    local hrpPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
    
    local visible = Config.Visuals.Enabled
    if Config.Visuals.TeamCheck and player.Team == LocalPlayer.Team then visible = false end
    
    if onScreen and visible then
        local topPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        local bottomPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
        local height = math.abs(topPos.Y - bottomPos.Y)
        local width = height / 1.5
        
        if Config.Visuals.Box then
            drawings.Box.Size = Vector2.new(width, height)
            drawings.Box.Position = Vector2.new(hrpPos.X - width / 2, hrpPos.Y - height / 2)
            drawings.Box.Visible = true
        else drawings.Box.Visible = false end
        
        if Config.Visuals.Name then
            drawings.Name.Text = player.Name
            drawings.Name.Position = Vector2.new(hrpPos.X, hrpPos.Y - height / 2 - 15)
            drawings.Name.Visible = true
        else drawings.Name.Visible = false end
        
        if Config.Visuals.Skeleton then
            local function getPos(part)
                if not part then return nil end
                local p, os = Camera:WorldToViewportPoint(part.Position)
                return os and Vector2.new(p.X, p.Y) or nil
            end
            local lines = {}
            if parts.Humanoid.RigType == Enum.HumanoidRigType.R15 then
                lines = {
                    {parts.Head, parts.UpperTorso}, {parts.UpperTorso, parts.LowerTorso},
                    {parts.UpperTorso, parts.LeftUpperArm}, {parts.LeftUpperArm, parts.LeftLowerArm},
                    {parts.LeftLowerArm, parts.LeftHand}, {parts.UpperTorso, parts.RightUpperArm},
                    {parts.RightUpperArm, parts.RightLowerArm}, {parts.RightLowerArm, parts.RightHand},
                    {parts.LowerTorso, parts.LeftUpperLeg}, {parts.LeftUpperLeg, parts.LeftLowerLeg},
                    {parts.LeftLowerLeg, parts.LeftFoot}, {parts.LowerTorso, parts.RightUpperLeg},
                    {parts.RightUpperLeg, parts.RightLowerLeg}, {parts.RightLowerLeg, parts.RightFoot}
                }
            else
                lines = {
                    {parts.Head, parts.Torso}, {parts.Torso, parts["Left Arm"]},
                    {parts.Torso, parts["Right Arm"]}, {parts.Torso, parts["Left Leg"]},
                    {parts.Torso, parts["Right Leg"]}
                }
            end
            for i, pList in ipairs(lines) do
                local p1 = getPos(pList[1]); local p2 = getPos(pList[2])
                if p1 and p2 and drawings.Skeleton[i] then
                    drawings.Skeleton[i].From = p1; drawings.Skeleton[i].To = p2; drawings.Skeleton[i].Visible = true
                elseif drawings.Skeleton[i] then drawings.Skeleton[i].Visible = false end
            end
        else for _, line in pairs(drawings.Skeleton) do line.Visible = false end end
    else
        drawings.Box.Visible = false; drawings.Name.Visible = false
        for _, line in pairs(drawings.Skeleton) do line.Visible = false end
    end
end

-- Main Loop
local RenderSteppedConnection
RenderSteppedConnection = RunService.RenderStepped:Connect(function()
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOVCircle.Position = screenCenter; FOVCircle.Radius = Config.Aimbot.FOV; FOVCircle.Visible = Config.Aimbot.ShowFOV
    SilentFOVCircle.Position = screenCenter; SilentFOVCircle.Radius = Config.SilentAim.FOV; SilentFOVCircle.Visible = Config.SilentAim.ShowFOV
    
    TriggerAimBox.Position = Config.TriggerAim.Position; TriggerAimBox.Size = Vector2.new(Config.TriggerAim.SizeX, Config.TriggerAim.SizeY); TriggerAimBox.Visible = Config.TriggerAim.Show; TriggerAimBox.Transparency = Config.TriggerAim.Transparency; TriggerAimBox.Color = Config.TriggerAim.Color
    TriggerShootBox.Position = Config.TriggerShoot.Position; TriggerShootBox.Size = Vector2.new(Config.TriggerShoot.SizeX, Config.TriggerShoot.SizeY); TriggerShootBox.Visible = Config.TriggerShoot.Show; TriggerShootBox.Transparency = Config.TriggerShoot.Transparency; TriggerShootBox.Color = Config.TriggerShoot.Color

    if Config.Aimbot.Enabled and (Config.Aimbot.AimActive or Config.Aimbot.ShootActive) then
        local target = GetClosestPlayer(Config.Aimbot.FOV, Config.Aimbot.TeamCheck, Config.Aimbot.VisibleCheck, Config.Aimbot.TargetPart)
        if target and CharacterCache[target] then
            local parts = CharacterCache[target]
            local part = parts[Config.Aimbot.TargetPart]
            if not part and Config.Aimbot.TargetPart == "HumanoidRootPart" then
                part = parts["Torso"] or parts["UpperTorso"]
            end
            if part then
                if Config.Aimbot.Smoothness <= 0 then
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, part.Position)
                else
                    local lerpAmount = (1 - Config.Aimbot.Smoothness) * 0.25 + 0.005
                    Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, part.Position), lerpAmount)
                end
            end
        end
    end
    
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local hum = LocalPlayer.Character.Humanoid
        hum.HipHeight = Config.Misc.CustomCrouch and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and Config.Misc.CrouchOffset or Config.Misc.OriginalHipHeight
    end

    for player, drawings in pairs(ESP_Objects) do UpdateESP(player, drawings) end
end)

