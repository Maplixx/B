-- Drawing API Elements
local function CreateCircle(color, filled)
    local c = Drawing.new("Circle")
    c.Visible = false
    c.Thickness = 1
    c.NumSides = 64
    c.Filled = filled or false
    c.Color = color
    return c
end

local function CreateSquare(color, filled)
    local s = Drawing.new("Square")
    s.Visible = false
    s.Thickness = 1
    s.Filled = filled or false
    s.Color = color
    return s
end

