-- Utility Functions
local function IsVisible(part)
    if not part then return false end
    local char = LocalPlayer.Character
    if not char then return false end
    
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {char, Camera}
    
    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin).Unit * (part.Position - origin).Magnitude
    
    local result = workspace:Raycast(origin, direction, params)
    
    if result and result.Instance:IsDescendantOf(part.Parent) then
        return true
    end
    return false
end

local function GetClosestPlayer(fov, teamCheckEnabled, visibleCheckEnabled, targetPartName)
    local target = nil
    local shortestDistance = fov or math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            if teamCheckEnabled and player.Team == LocalPlayer.Team then continue end
            
            local part = player.Character:FindFirstChild(targetPartName)
            if not part and targetPartName == "HumanoidRootPart" then
                part = player.Character:FindFirstChild("Torso") or player.Character:FindFirstChild("UpperTorso")
            end

            if part then
                if visibleCheckEnabled and not IsVisible(part) then continue end
                
                local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local distance = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
                    if distance < shortestDistance then
                        target = player
                        shortestDistance = distance
                    end
                end
            end
        end
    end
    return target
end

-- METATABLE HOOKING
local mt = getrawmetatable(game)
local oldIndex = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(self, index)
    if not checkcaller() and self == Mouse and (index == "Hit" or index == "Target") then
        if Config.SilentAim.Enabled then
            local target = GetClosestPlayer(Config.SilentAim.FOV, Config.SilentAim.TeamCheck, Config.SilentAim.VisibleCheck, Config.SilentAim.TargetPart)
            if target and target.Character then
                local part = target.Character:FindFirstChild(Config.SilentAim.TargetPart)
                if not part and Config.SilentAim.TargetPart == "HumanoidRootPart" then
                    part = target.Character:FindFirstChild("Torso") or target.Character:FindFirstChild("UpperTorso")
                end
                
                if part then
                    if index == "Hit" then
                        return part.CFrame
                    elseif index == "Target" then
                        return part
                    end
                end
            end
        end
    end
    return oldIndex(self, index)
end)

setreadonly(mt, true)

-- Dual Trigger Detection
UserInputService.InputBegan:Connect(function(input, processed)
    if not processed and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
        local touchPos = Vector2.new(input.Position.X, input.Position.Y)
        if (touchPos - Config.TriggerAim.Position).Magnitude <= Config.TriggerAim.Size then
            Config.Aimbot.AimActive = true
        end
        if (touchPos - Config.TriggerShoot.Position).Magnitude <= Config.TriggerShoot.Size then
            Config.Aimbot.ShootActive = true
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        Config.Aimbot.AimActive = false
        Config.Aimbot.ShootActive = false
    end
end)

-- ESP Logic (Fixed)
local function CreateESP(player)
    local drawings = { Box = Drawing.new("Square"), Name = Drawing.new("Text"), Skeleton = {} }
    drawings.Box.Visible = false; drawings.Box.Color = Config.Visuals.Color; drawings.Box.Thickness = 1; drawings.Box.Filled = false
    drawings.Name.Visible = false; drawings.Name.Color = Config.Visuals.Color; drawings.Name.Size = 14; drawings.Name.Center = true; drawings.Name.Outline = true
    for i = 1, 15 do
        local line = Drawing.new("Line")
        line.Visible = false; line.Color = Config.Visuals.Color; line.Thickness = 1
        drawings.Skeleton[i] = line
    end
    ESP_Objects[player] = drawings
end

local function UpdateESP(player, drawings)
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
        drawings.Box.Visible = false; drawings.Name.Visible = false
        for _, line in pairs(drawings.Skeleton) do line.Visible = false end
        return
    end
    local hrp = character.HumanoidRootPart
    local head = character:FindFirstChild("Head")
    if not head then return end
    local hrpPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
    local visible = Config.Visuals.Enabled
    if Config.Visuals.TeamCheck and player.Team == LocalPlayer.Team then visible = false end
    if onScreen and visible then
        local topPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        local bottomPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
        local height = math.abs(topPos.Y - bottomPos.Y)
        local width = height / 1.5
        if Config.Visuals.Box then
            drawings.Box.Size = Vector2.new(width, height)
            drawings.Box.Position = Vector2.new(hrpPos.X - width / 2, hrpPos.Y - height / 2)
            drawings.Box.Visible = true
        else drawings.Box.Visible = false end
        if Config.Visuals.Name then
            drawings.Name.Text = player.Name
            drawings.Name.Position = Vector2.new(hrpPos.X, hrpPos.Y - height / 2 - 15)
            drawings.Name.Visible = true
        else drawings.Name.Visible = false end
        if Config.Visuals.Skeleton then
            local function getPart(name) return character:FindFirstChild(name) end
            local function getPos(part)
                if not part then return nil end
                local p, os = Camera:WorldToViewportPoint(part.Position)
                return os and Vector2.new(p.X, p.Y) or nil
            end
            local lines = {}
            if character.Humanoid.RigType == Enum.HumanoidRigType.R15 then
                lines = {
                    {getPart("Head"), getPart("UpperTorso")}, {getPart("UpperTorso"), getPart("LowerTorso")},
                    {getPart("UpperTorso"), getPart("LeftUpperArm")}, {getPart("LeftUpperArm"), getPart("LeftLowerArm")},
                    {getPart("LeftLowerArm"), getPart("LeftHand")}, {getPart("UpperTorso"), getPart("RightUpperArm")},
                    {getPart("RightUpperArm"), getPart("RightLowerArm")}, {getPart("RightLowerArm"), getPart("RightHand")},
                    {getPart("LowerTorso"), getPart("LeftUpperLeg")}, {getPart("LeftUpperLeg"), getPart("LeftLowerLeg")},
                    {getPart("LeftLowerLeg"), getPart("LeftFoot")}, {getPart("LowerTorso"), getPart("RightUpperLeg")},
                    {getPart("RightUpperLeg"), getPart("RightLowerLeg")}, {getPart("RightLowerLeg"), getPart("RightFoot")}
                }
            else
                lines = {
                    {getPart("Head"), getPart("Torso")}, {getPart("Torso"), getPart("Left Arm")},
                    {getPart("Torso"), getPart("Right Arm")}, {getPart("Torso"), getPart("Left Leg")},
                    {getPart("Torso"), getPart("Right Leg")}
                }
            end
            for i, parts in ipairs(lines) do
                local p1 = getPos(parts[1]); local p2 = getPos(parts[2])
                if p1 and p2 and drawings.Skeleton[i] then
                    drawings.Skeleton[i].From = p1; drawings.Skeleton[i].To = p2; drawings.Skeleton[i].Visible = true
                elseif drawings.Skeleton[i] then drawings.Skeleton[i].Visible = false end
            end
            for i = #lines + 1, 15 do if drawings.Skeleton[i] then drawings.Skeleton[i].Visible = false end end
        else for _, line in pairs(drawings.Skeleton) do line.Visible = false end end
    else
        drawings.Box.Visible = false; drawings.Name.Visible = false
        for _, line in pairs(drawings.Skeleton) do line.Visible = false end
    end
end

-- Main Loop
local RenderSteppedConnection
RenderSteppedConnection = RunService.RenderStepped:Connect(function()
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOVCircle.Position = screenCenter; FOVCircle.Radius = Config.Aimbot.FOV; FOVCircle.Visible = Config.Aimbot.ShowFOV
    SilentFOVCircle.Position = screenCenter; SilentFOVCircle.Radius = Config.SilentAim.FOV; SilentFOVCircle.Visible = Config.SilentAim.ShowFOV
    
    -- Triggers UI Update
    TriggerAimCircle.Position = Config.TriggerAim.Position; TriggerAimCircle.Radius = Config.TriggerAim.Size; TriggerAimCircle.Visible = Config.TriggerAim.Show; TriggerAimCircle.Transparency = Config.TriggerAim.Transparency; TriggerAimCircle.Color = Config.TriggerAim.Color
    TriggerShootCircle.Position = Config.TriggerShoot.Position; TriggerShootCircle.Radius = Config.TriggerShoot.Size; TriggerShootCircle.Visible = Config.TriggerShoot.Show; TriggerShootCircle.Transparency = Config.TriggerShoot.Transparency; TriggerShootCircle.Color = Config.TriggerShoot.Color

    -- Mobile Aimbot Logic (Dual Trigger)
    if Config.Aimbot.Enabled and (Config.Aimbot.AimActive or Config.Aimbot.ShootActive) then
        local target = GetClosestPlayer(Config.Aimbot.FOV, Config.Aimbot.TeamCheck, Config.Aimbot.VisibleCheck, Config.Aimbot.TargetPart)
        if target and target.Character then
            local part = target.Character:FindFirstChild(Config.Aimbot.TargetPart)
            if not part and Config.Aimbot.TargetPart == "HumanoidRootPart" then
                part = target.Character:FindFirstChild("Torso") or target.Character:FindFirstChild("UpperTorso")
            end
            if part then
                if Config.Aimbot.Smoothness <= 0 then
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, part.Position)
                else
                    local lerpAmount = (1 - Config.Aimbot.Smoothness) * 0.25 + 0.005
                    Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, part.Position), lerpAmount)
                end
            end
        end
    end
    
    -- HipHeight Crouch (Stable)
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local hum = LocalPlayer.Character.Humanoid
        if Config.Misc.CustomCrouch and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            hum.HipHeight = Config.Misc.CrouchOffset
        else
            hum.HipHeight = Config.Misc.OriginalHipHeight
        end
    end

    for player, drawings in pairs(ESP_Objects) do UpdateESP(player, drawings) end
end)

